.container {
  padding: 16px;
}

.section {
  margin-bottom: 20px;
}

.label {
  font-size: 14px;
  color: #475569;
  margin-bottom: 8px;
  display: block;
}

.picker-value {
  background: #fff;
  border-radius: 10px;
  padding: 12px 14px;
  font-size: 14px;
  color: #1E293B;
}

.content-input {
  background: #fff;
  border-radius: 10px;
  padding: 12px 14px;
  width: 100%;
  min-height: 150px;
  font-size: 15px;
  line-height: 1.6;
  box-sizing: border-box;
}

.char-count {
  text-align: right;
  font-size: 12px;
  color: #94A3B8;
  margin-top: 4px;
}

.save-btn {
  background: #2563EB;
  color: #fff;
  border-radius: 12px;
  font-size: 16px;
  padding: 14px;
  margin-top: 8px;
  border: none;
}

.danger-zone {
  margin-top: 40px;
  padding-top: 20px;
  border-top: 1px solid #E2E8F0;
}

.delete-btn {
  background: #fff;
  color: #EF4444;
  border: 1px solid #FCA5A5;
  border-radius: 12px;
  font-size: 14px;
  padding: 12px;
}