.container {
  padding: 16px;
  padding-bottom: 40px;
}

.key-section {
  background: #F8FAFC;
  border-radius: 12px;
  padding: 14px;
  margin-bottom: 16px;
}

.key-section.configured {
  background: #F0FDF4;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.key-status {
  font-size: 14px;
  color: #16A34A;
}

.key-change {
  font-size: 12px;
  color: #2563EB;
}

.key-row {
  margin-bottom: 8px;
}

.key-input {
  background: #fff !important;
  border-radius: 10px;
  padding: 10px 14px;
  width: 100%;
  font-size: 13px;
  box-sizing: border-box;
}

.key-btns {
  display: flex;
  gap: 8px;
  margin-top: 8px;
}

.btn-sm {
  flex: 1;
  background: #2563EB;
  color: #fff;
  font-size: 13px;
  padding: 8px;
  border-radius: 8px;
  border: none;
}

.btn-sm.outline {
  background: #fff;
  color: #64748B;
  border: 1px solid #E2E8F0;
}

.hint {
  display: block;
  font-size: 11px;
  color: #94A3B8;
  margin-top: 6px;
}

.section {
  margin-bottom: 16px;
}

.label {
  font-size: 14px;
  color: #475569;
  margin-bottom: 8px;
  display: block;
}

.input-area {
  background: #fff;
  border-radius: 10px;
  padding: 12px 14px;
  width: 100%;
  min-height: 100px;
  font-size: 15px;
  box-sizing: border-box;
}

.input-field {
  background: #fff;
  border-radius: 10px;
  padding: 12px 14px;
  width: 100%;
  font-size: 14px;
  box-sizing: border-box;
}

.scenario-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.s-tab {
  padding: 6px 14px;
  border-radius: 20px;
  font-size: 13px;
  background: #fff;
  color: #64748B;
}

.s-tab.active {
  background: #2563EB;
  color: #fff;
}

.gen-btn {
  background: #2563EB;
  color: #fff;
  border-radius: 12px;
  font-size: 16px;
  padding: 14px;
  margin-top: 8px;
  border: none;
}

.gen-btn[disabled] {
  background: #94A3B8;
}

.error-box {
  margin-top: 16px;
  padding: 12px;
  background: #FEF2F2;
  border-radius: 10px;
  color: #DC2626;
  font-size: 14px;
}

.results {
  margin-top: 20px;
}

.reply-card {
  background: #fff;
  border-radius: 12px;
  padding: 14px;
  margin-bottom: 12px;
}

.reply-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.reply-label {
  font-size: 13px;
  color: #2563EB;
  font-weight: 600;
}

.copy-sm {
  background: #EFF6FF;
  color: #2563EB;
  font-size: 12px;
  padding: 4px 12px;
  border-radius: 6px;
  border: none;
}

.reply-text {
  font-size: 14px;
  line-height: 1.6;
  color: #334155;
}