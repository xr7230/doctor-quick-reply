<view class="container">
  <!-- API key config -->
  <view class="key-section" wx:if="{{!hasKey}}">
    <text class="label">DeepSeek API Key（仅本地存储）</text>
    <view class="key-row">
      <input class="input-field key-input" value="{{apiKey}}" placeholder="sk-..." bindinput="onKeyInput" password="{{true}}" />
    </view>
    <button class="gen-btn" bindtap="saveKey" style="margin-top:8px">保存密钥</button>
    <text class="hint">Key 仅保存在手机本地，不会上传。获取地址：platform.deepseek.com</text>
  </view>

  <view class="key-section configured" wx:if="{{hasKey}}" bindtap="showKeySettings">
    <text class="key-status">API Key 已配置</text>
    <text class="key-change">点击修改</text>
  </view>

  <view class="key-section" wx:if="{{showKeyEdit}}">
    <input class="input-field key-input" value="{{apiKey}}" placeholder="sk-..." bindinput="onKeyInput" password="{{true}}" />
    <view class="key-btns">
      <button class="btn-sm" bindtap="saveKey">保存</button>
      <button class="btn-sm outline" bindtap="cancelKey">取消</button>
    </view>
  </view>

  <!-- doctor input -->
  <view class="section">
    <text class="label">医生想对患者说什么</text>
    <textarea class="input-area" value="{{doctorInput}}" placeholder="例如：继续按原方案治疗，下个月复查CT" bindinput="onInput" maxlength="300" auto-height />
  </view>

  <!-- patient context -->
  <view class="section">
    <text class="label">患者背景</text>
    <input class="input-field" value="{{patientContext}}" placeholder="例如：35岁女性，肺癌术后1年" bindinput="onCtxInput" />
  </view>

  <!-- scenario -->
  <view class="section">
    <text class="label">场景</text>
    <view class="scenario-tabs">
      <view wx:for="{{scenarios}}" wx:key="*this" class="s-tab {{scenario === item ? 'active' : ''}}" bindtap="setScenario" data-s="{{item}}">{{item}}</view>
    </view>
  </view>

  <!-- generate button -->
  <button class="gen-btn" bindtap="generate" disabled="{{loading || !hasKey}}">
    {{loading ? '生成中...' : hasKey ? 'AI 生成回复' : '请先配置 API Key'}}
  </button>

  <!-- error -->
  <view wx:if="{{error}}" class="error-box">{{error}}</view>

  <!-- results -->
  <view wx:if="{{replies}}" class="results">
    <view class="reply-card">
      <view class="reply-header">
        <text class="reply-label">温暖详细</text>
        <button class="copy-sm" bindtap="copy" data-content="{{replies.versionA}}">复制</button>
      </view>
      <text class="reply-text">{{replies.versionA}}</text>
    </view>
    <view class="reply-card">
      <view class="reply-header">
        <text class="reply-label">简洁直接</text>
        <button class="copy-sm" bindtap="copy" data-content="{{replies.versionB}}">复制</button>
      </view>
      <text class="reply-text">{{replies.versionB}}</text>
    </view>
    <view class="reply-card">
      <view class="reply-header">
        <text class="reply-label">鼓励支持</text>
        <button class="copy-sm" bindtap="copy" data-content="{{replies.versionC}}">复制</button>
      </view>
      <text class="reply-text">{{replies.versionC}}</text>
    </view>
  </view>
</view>